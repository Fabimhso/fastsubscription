<div>
  <h1 class="font-bold text-4xl">Support#index</h1>
  <p>Find me in app/views/support/index.html.erb</p>
</div>

<div class="w-full flex justify-center animated-bg overflow-x-hidden mt-16">
  <div class="fade-in bg-white/60 backdrop-blur-lg rounded-3xl shadow-lg p-8 w-full max-w-lg">
    <h2 class="text-2xl font-bold text-center text-blue-700 mb-6">Contact Support</h2>
    <form action="#" method="post" class="space-y-6">
      <div>
        <label for="support_subject" class="block text-gray-700 font-semibold mb-1">Subject</label>
        <input type="text" id="support_subject" name="support[subject]" class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400" placeholder="Subject" required />
      </div>
      <div>
        <label for="support_message" class="block text-gray-700 font-semibold mb-1">Message</label>
        <textarea id="support_message" name="support[message]" rows="4" class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400" placeholder="Describe your issue or question..." required></textarea>
      </div>
      <div>
        <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-4 rounded-lg text-lg shadow transition">Send Message</button>
      </div>
    </form>
  </div>
</div>
