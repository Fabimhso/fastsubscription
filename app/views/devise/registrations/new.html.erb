<div class="w-full flex justify-center animated-bg overflow-x-hidden mt-16">
  <div class="fade-in bg-white/60 backdrop-blur-lg rounded-3xl shadow-lg p-8 w-full max-w-md max-h-[90vh] overflow-auto">
    <h2 class="text-2xl font-bold text-center text-blue-700 mb-6">Criar conta no FastSubscription</h2>
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="mb-4">
        <%= f.label :email, class: 'block text-left text-gray-700 font-semibold mb-1' %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: 'w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400' %>
      </div>

      <div class="mb-4">
        <%= f.label :password, class: 'block text-left text-gray-700 font-semibold mb-1' %>
        <% if @minimum_password_length %>
        <em>(<%= @minimum_password_length %> characters minimum)</em>
        <% end %><br />
        <%= f.password_field :password, autocomplete: "new-password", class: 'w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400' %>
      </div>

      <div class="mb-6">
        <%= f.label :password_confirmation, class: 'block text-left text-gray-700 font-semibold mb-1' %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: 'w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400' %>
      </div>

      <div class="mb-6">
        <%= f.submit "Criar conta", class: 'w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-4 rounded-lg text-lg shadow transition' %>
      </div>
    <% end %>
    <div class="flex justify-between text-sm">
      <%= link_to "Entrar", new_session_path(resource_name), class: 'text-blue-600 hover:underline' %>
      <%= link_to "Esqueci minha senha", new_password_path(resource_name), class: 'text-blue-600 hover:underline' %>
    </div>
  </div>
</div>
