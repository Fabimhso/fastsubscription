<div class="w-full flex justify-center animated-bg overflow-x-hidden mt-16">
  <div class="fade-in bg-white/60 backdrop-blur-lg rounded-3xl shadow-lg p-8 w-full max-w-4xl">
    <div class="flex justify-between items-center mb-6">
      <h2 class="text-2xl font-bold text-blue-700">My Projects</h2>
      <%= link_to new_project_path, class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg transition-colors" do %>
        <i class="fas fa-plus mr-2"></i>New Project
      <% end %>
    </div>
    
    <% if @projects.any? %>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <% @projects.each do |project| %>
          <div class="bg-white rounded-xl shadow p-5 flex flex-col">
            <h3 class="text-lg font-bold text-blue-800 mb-2"><%= project.name %></h3>
            <p class="text-gray-700 flex-1 mb-4"><%= project.description.presence || 'No description.' %></p>
            <span class="text-xs text-gray-400 mb-3">Created at: <%= project.created_at.strftime('%d/%m/%Y %H:%M') %></span>
            
            <div class="flex gap-2 mt-auto">
              <%= link_to project_path(project), class: "bg-blue-500 hover:bg-blue-600 text-white px-3 py-1 rounded text-sm transition-colors" do %>
                <i class="fas fa-eye mr-1"></i>View
              <% end %>
              <%= link_to edit_project_path(project), class: "bg-yellow-500 hover:bg-yellow-600 text-white px-3 py-1 rounded text-sm transition-colors" do %>
                <i class="fas fa-edit mr-1"></i>Edit
              <% end %>
              <%= link_to project_path(project), 
                  method: :delete, 
                  data: { confirm: 'Are you sure you want to delete this project?' },
                  class: "bg-red-500 hover:bg-red-600 text-white px-3 py-1 rounded text-sm transition-colors" do %>
                <i class="fas fa-trash mr-1"></i>Delete
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-8">
        <i class="fas fa-folder-open text-6xl text-gray-300 mb-4"></i>
        <p class="text-gray-500 text-lg mb-4">You have no projects yet.</p>
        <%= link_to new_project_path, class: "bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg transition-colors inline-flex items-center" do %>
          <i class="fas fa-plus mr-2"></i>Create your first project
        <% end %>
      </div>
    <% end %>
  </div>
</div> 