<div class="w-full flex justify-center animated-bg overflow-x-hidden mt-16">
  <div class="fade-in bg-white/60 backdrop-blur-lg rounded-3xl shadow-lg p-8 w-full max-w-4xl">
    <div class="flex justify-between items-center mb-6">
      <h2 class="text-2xl font-bold text-blue-700">Project Details</h2>
      <div class="flex gap-2">
        <%= link_to edit_project_path(@project), class: "bg-yellow-500 hover:bg-yellow-600 text-white px-4 py-2 rounded-lg transition-colors" do %>
          <i class="fas fa-edit mr-2"></i>Edit
        <% end %>
        <%= link_to projects_path, class: "bg-gray-500 hover:bg-gray-600 text-white px-4 py-2 rounded-lg transition-colors" do %>
          <i class="fas fa-arrow-left mr-2"></i>Back
        <% end %>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- Detalhes do Projeto -->
      <div class="bg-white rounded-xl shadow p-6">
        <h3 class="text-xl font-bold text-blue-800 mb-4">Project Information</h3>
        
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
            <p class="text-lg text-gray-900"><%= @project.name %></p>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
            <p class="text-gray-900"><%= @project.description %></p>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Created</label>
            <p class="text-gray-900"><%= @project.created_at.strftime('%d/%m/%Y at %H:%M') %></p>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Last Updated</label>
            <p class="text-gray-900"><%= @project.updated_at.strftime('%d/%m/%Y at %H:%M') %></p>
          </div>
        </div>
        
        <div class="mt-6 pt-4 border-t border-gray-200">
          <%= link_to project_path(@project), 
              method: :delete, 
              data: { confirm: 'Are you sure you want to delete this project? This action cannot be undone.' },
              class: "bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-lg transition-colors inline-flex items-center" do %>
            <i class="fas fa-trash mr-2"></i>Delete Project
          <% end %>
        </div>
      </div>

      <!-- Histórico do Projeto -->
      <div class="bg-white rounded-xl shadow p-6">
        <h3 class="text-xl font-bold text-blue-800 mb-4">Project History</h3>
        
        <% if @histories.any? %>
          <div class="space-y-3 max-h-96 overflow-y-auto">
            <% @histories.each do |history| %>
              <div class="border-l-4 border-blue-500 pl-4 py-2">
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-2">
                    <% case history.action %>
                    <% when 'created' %>
                      <i class="fas fa-plus-circle text-green-500"></i>
                    <% when 'updated' %>
                      <i class="fas fa-edit text-yellow-500"></i>
                    <% when 'deleted' %>
                      <i class="fas fa-trash text-red-500"></i>
                    <% end %>
                    <span class="font-medium text-gray-900"><%= history.action.humanize %></span>
                  </div>
                  <span class="text-xs text-gray-500"><%= history.created_at.strftime('%d/%m %H:%M') %></span>
                </div>
                <p class="text-sm text-gray-600 mt-1"><%= history.description %></p>
                <p class="text-xs text-gray-400 mt-1">by <%= history.user.email %></p>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-8">
            <i class="fas fa-history text-4xl text-gray-300 mb-2"></i>
            <p class="text-gray-500">No history available for this project.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div> 